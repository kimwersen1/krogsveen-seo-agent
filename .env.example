# Ahrefs API v3 — Account settings > API keys i Ahrefs
AHREFS_API_KEY=
AHREFS_PROJECT_ID=8825594

# Google service account — trengs KUN for å skrive rapporten til Drive.
# GSC-data hentes via OAuth (se GOOGLE_OAUTH_*/src/collectors/gsc_oauth.py, anbefalt) eller
# manuell CSV-eksport (src/collectors/gsc.py) som reserveløsning — denne kontoen trenger
# ingen Search Console-tilgang selv, bare at noen deler Drive-mappen under med kontoens
# e-postadresse (Redaktør).
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service-account.json

# Google Drive — mappen "SEO-rapporter Krogsveen"
GOOGLE_DRIVE_FOLDER_ID=1bHjPT1HVyDvL7StnI1DREpIYc96ofzdg

# Navnet på det løpende rapport-dokumentet i mappen over. MÅ opprettes manuelt av et
# menneske (ikke service-kontoen — se src/report/drive_writer.py for hvorfor) med
# nøyaktig dette navnet, delt med service-kontoen som Redaktør. Ukens rapport settes
# inn øverst i dette dokumentet ved hver kjøring, nyeste først.
GOOGLE_REPORT_DOC_NAME=SEO-ukentlig rapport Krogsveen

# Navnet på det løpende dashboard-regnearket i samme mappe. Samme regel som over —
# MÅ opprettes manuelt (tomt Google Sheet, nøyaktig dette navnet), service-kontoen
# kan ikke opprette det selv. Faner og diagrammer settes opp automatisk ved første kjøring.
GOOGLE_DASHBOARD_SHEET_NAME=SEO-dashboard Krogsveen

# Anthropic — for å skrive selve rapportteksten + Claude-GEO-selvsjekken (alltid på)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI — valgfri ChatGPT-GEO-selvsjekk (src/collectors/chatgpt_geo.py). Krever en
# API-nøkkel fra platform.openai.com (IKKE samme som en vanlig chatgpt.com-innlogging —
# faktureres separat). Hopper stille over seg selv i pipelinen hvis denne står tom.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Search Console — valgfritt, men anbefalt (erstatter manuell CSV-eksport med
# automatisk henting av klikk/CTR per søkeord og side). Krever en OAuth-klient (type
# "Desktop app") opprettet i Google Cloud Console, og at DIN egen Google-konto har minst
# "Begrenset" tilgang til eiendommen i Search Console. Kjør scripts/gsc_auth_setup.py
# én gang for å generere GOOGLE_OAUTH_REFRESH_TOKEN — se scriptets docstring for detaljer.
# Pipeline.py faller tilbake til manuell CSV-import (--gsc-query-export) hvis disse
# mangler, så alt annet fortsetter å fungere uten dem.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_SEARCH_CONSOLE_PROPERTY=sc-domain:krogsveen.no

# Gemini — valgfri GEO-selvsjekk, del av erstatningen for Ahrefs Brand Radar (21.07.2026:
# Brand Radar var begrenset til 5 prompts uten skriv-API for rotasjon). Gratis å komme i
# gang med via aistudio.google.com/apikey (generøs gratis kvote). Hopper stille over seg
# selv i pipelinen hvis denne står tom.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# Perplexity — valgfri GEO-selvsjekk, samme begrunnelse som Gemini over. Betalt
# (perplexity.ai/settings/api), men billig per kall. Sonar-modellene gjør alltid live
# websøk og returnerer siterte kilde-URL-er, så denne sjekken kan avgjøre om
# krogsveen.no faktisk SITERES — ikke bare om merket nevnes i teksten (sterkere
# GEO-signal enn de andre selvsjekkene). Hopper stille over seg selv uten nøkkel.
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
