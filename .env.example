# Ahrefs API v3 — Account settings > API keys i Ahrefs
AHREFS_API_KEY=
AHREFS_PROJECT_ID=8825594
AHREFS_BRAND_RADAR_REPORT_ID=019f5beb-5f1a-7d06-ae2d-4458c86782ee

# Google service account — trengs KUN for å skrive rapporten til Drive.
# GSC-data hentes via Ahrefs (se src/collectors/ahrefs.py) + manuell CSV-eksport
# (se src/collectors/gsc.py), så denne kontoen trenger ingen Search Console-tilgang —
# bare at noen deler Drive-mappen under med kontoens e-postadresse (Redaktør).
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service-account.json

# Google Drive — mappen "SEO-rapporter Krogsveen"
GOOGLE_DRIVE_FOLDER_ID=1bHjPT1HVyDvL7StnI1DREpIYc96ofzdg

# Navnet på det løpende rapport-dokumentet i mappen over. MÅ opprettes manuelt av et
# menneske (ikke service-kontoen — se src/report/drive_writer.py for hvorfor) med
# nøyaktig dette navnet, delt med service-kontoen som Redaktør. Ukens rapport settes
# inn øverst i dette dokumentet ved hver kjøring, nyeste først.
GOOGLE_REPORT_DOC_NAME=SEO-ukentlig rapport Krogsveen

# Navnet på det løpende dashboard-regnearket i samme mappe. Samme regel som over —
# MÅ opprettes manuelt (tomt Google Sheet, nøyaktig dette navnet), service-kontoen
# kan ikke opprette det selv. Faner og diagrammer settes opp automatisk ved første kjøring.
GOOGLE_DASHBOARD_SHEET_NAME=SEO-dashboard Krogsveen

# Anthropic — for å skrive selve rapportteksten + Claude-GEO-selvsjekken (alltid på)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# OpenAI — valgfri ChatGPT-GEO-selvsjekk (src/collectors/chatgpt_geo.py). Krever en
# API-nøkkel fra platform.openai.com (IKKE samme som en vanlig chatgpt.com-innlogging —
# faktureres separat). Hopper stille over seg selv i pipelinen hvis denne står tom.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
